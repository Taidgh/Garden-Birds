# BirdNET-Go instance URL
BIRDNET_URL=http://192.168.1.70:8080

# How often to poll BirdNET-Go (milliseconds)
POLL_INTERVAL=30000

# Backend port (internal)
BACKEND_PORT=3001

# Frontend port (the website you visit)
FRONTEND_PORT=8080

# Admin panel credentials
ADMIN_USER=admin
ADMIN_PASS=Change-This-Password

# Cloudflare WAF secret (optional - leave blank if not using WAF)
BIRD_SECRET=

# Cloudflare Service Token (optional - leave blank if not using CF Access)
CF_CLIENT_ID=
CF_CLIENT_SECRET=
